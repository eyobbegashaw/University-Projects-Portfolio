<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
      spacing="20" styleClass="form-panel" fx:controller="com.grainmill.controller.customer.NewOrderController">
   <children>
      <Label text="Place New Order" styleClass="section-title" />
      
      <VBox spacing="15" styleClass="form-section">
         <Label text="Grain Information" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
         <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="5">
               <Label text="Grain Type *" />
               <ComboBox fx:id="grainTypeCombo" prefWidth="200" />
            </VBox>
            
            <VBox spacing="5">
               <Label text="Estimated Weight (KG) *" />
               <TextField fx:id="weightField" promptText="Enter weight" prefWidth="150" />
            </VBox>
         </HBox>
      </VBox>
      
      <VBox spacing="15" styleClass="form-section">
         <Label text="Service Type" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
         <ToggleGroup fx:id="serviceGroup" />
         <VBox spacing="10">
            <RadioButton text="እህል ከቤቴ ይውሰዱ (Pickup grain from my location)" 
                        toggleGroup="$serviceGroup" userData="PICKUP" selected="true" />
            <RadioButton text="የተፈጨ ዱቄት ብቻ ያምጡልኝ (Deliver milled flour only)" 
                        toggleGroup="$serviceGroup" userData="DELIVERY" />
         </VBox>
      </VBox>
      
      <VBox spacing="15" styleClass="form-section">
         <Label text="Delivery Information" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
         <VBox spacing="10">
            <HBox spacing="15">
               <VBox spacing="5">
                  <Label text="Full Address *" />
                  <TextField fx:id="addressField" promptText="Enter your complete address" 
                            prefWidth="400" />
               </VBox>
            </HBox>
            <HBox spacing="15">
               <VBox spacing="5">
                  <Label text="Phone Number *" />
                  <TextField fx:id="phoneField" promptText="Your phone number" prefWidth="200" />
               </VBox>
               <VBox spacing="5">
                  <Label text="Additional Notes" />
                  <TextField fx:id="notesField" promptText="Any special instructions" 
                            prefWidth="300" />
               </VBox>
            </HBox>
         </VBox>
      </VBox>
      
      <VBox spacing="15" styleClass="form-section">
         <Label text="Payment Information" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
         <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="10">
               <Label text="Estimated Cost Breakdown:" />
               <GridPane hgap="10" vgap="5">
                  <columnConstraints>
                     <ColumnConstraints prefWidth="150" />
                     <ColumnConstraints prefWidth="100" />
                  </columnConstraints>
                  
                  <Label text="Milling Cost:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                  <Label fx:id="millingCostLabel" text="0.00 ETB" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                  
                  <Label text="Transport Cost:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                  <Label fx:id="transportCostLabel" text="0.00 ETB" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                  
                  <Label text="Total Cost:" GridPane.rowIndex="2" GridPane.columnIndex="0" 
                        style="-fx-font-weight: bold;" />
                  <Label fx:id="totalCostLabel" text="0.00 ETB" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                        style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
               </GridPane>
            </VBox>
            
            <VBox spacing="10">
               <Label text="Payment Method *" />
               <ToggleGroup fx:id="paymentGroup" />
               <RadioButton text="Cash on Delivery" toggleGroup="$paymentGroup" 
                          userData="CASH_ON_DELIVERY" selected="true" />
               <RadioButton text="Online Payment" toggleGroup="$paymentGroup" 
                          userData="ONLINE" />
            </VBox>
         </HBox>
      </VBox>
      
      <HBox spacing="15" alignment="CENTER_RIGHT">
         <Button text="Calculate Cost" onAction="#calculateCost" styleClass="primary-button" />
         <Button text="Place Order" onAction="#placeOrder" styleClass="success-button" />
         <Button text="Clear" onAction="#clearForm" styleClass="warning-button" />
      </HBox>
   </children>
   
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>